{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "stock-api",
  "main": "src/server.ts",
  "minify": true,
  "compatibility_date": "2025-06-01",
  "observability": {
    "enabled": true,
  },
  "upload_source_maps": true,
  "compatibility_flags": ["nodejs_compat"],
  "ratelimits": [
    {
      "name": "RATE_LIMITER",
      "namespace_id": "1001",
      "simple": {
        "limit": 30,
        "period": 10,
      },
    },
  ],
}
